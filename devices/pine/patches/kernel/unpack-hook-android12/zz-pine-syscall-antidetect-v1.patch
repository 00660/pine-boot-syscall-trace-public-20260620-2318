+static bool pine_syscall_trace_scrub_secret_lines(char *buf, size_t len)
+{
+	char *line = buf;
+	char *end = buf + len;
+	char *line_end;
+	bool changed = false;
+
+	while (line < end) {
+		line_end = line;
+		while (line_end < end && *line_end != '\n')
+			line_end++;
+		if (pine_syscall_trace_line_has_secret(line, line_end - line)) {
+			memset(line, ' ', line_end - line);
+			changed = true;
+		}
+		line = line_end < end ? line_end + 1 : end;
+	}
+
+	return changed;
+}
+
+static bool pine_syscall_trace_scrub_tracerpid(char *buf, size_t len)
+{
+	static const char needle[] = "TracerPid:";
+	char *p = buf;
+	char *end = buf + len;
+	char *q;
+	bool changed = false;
+
+	while (p < end && (p = strnstr(p, needle, end - p)) != NULL) {
+		q = p + sizeof(needle) - 1;
+		while (q < end && (*q == ' ' || *q == '\t'))
+			q++;
+		if (q >= end || *q < '0' || *q > '9') {
+			p = q;
+			continue;
+		}
+		*q++ = '0';
+		while (q < end && *q >= '0' && *q <= '9')
+			*q++ = ' ';
+		changed = true;
+		p = q;
+	}
+
+	return changed;
+}

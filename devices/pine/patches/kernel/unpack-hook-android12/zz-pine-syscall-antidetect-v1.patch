+static bool pine_syscall_trace_ptrace_spoof(struct pt_regs *regs, bool compat)
+{
+	unsigned long request = regs->orig_x0;
+	unsigned long type = regs->regs[2];
+	unsigned long data = regs->regs[3];
+	unsigned long base = 0;
+	unsigned long len = 0;
+	unsigned long n;
+	struct pine_iovec64 iov64;
+	struct pine_iovec32 iov32;
+	int count;
+
+	if (!(READ_ONCE(pine_syscall_trace_policy) & PINE_POLICY_PTRACE))
+		return false;
+	if (request == PINE_PTRACE_TRACEME ||
+	    request == PINE_PTRACE_ATTACH ||
+	    request == PINE_PTRACE_SEIZE) {
+		pr_info("pine_syscall_trace type=ptrace_spoof name=ptrace action=anti_debug compat=%d pid=%d tgid=%d uid=%u request=%lx target=%lx comm=%s\n",
+			compat, task_pid_nr(current), task_tgid_nr(current),
+			from_kuid_munged(&init_user_ns, current_uid()),
+			request, regs->regs[1], current->comm);
+		pine_syscall_trace_skip(regs, 0);
+		return true;
+	}
+	if (request != PINE_PTRACE_GETREGSET && request != PINE_PTRACE_SETREGSET)
+		return false;
+	if (type != PINE_NT_ARM_HW_BREAK && type != PINE_NT_ARM_HW_WATCH)
+		return false;
+	if (!data)
+		return false;
+
+	if (compat) {
+		if (copy_from_user(&iov32, (void __user *)data, sizeof(iov32)))
+			return false;
+		base = iov32.iov_base;
+		len = iov32.iov_len;
+	} else {
+		if (copy_from_user(&iov64, (void __user *)data, sizeof(iov64)))
+			return false;
+		base = iov64.iov_base;
+		len = iov64.iov_len;
+	}
+
+	count = pine_syscall_trace_hwdebug_count(len);
+	if (request == PINE_PTRACE_SETREGSET && count > PINE_HWDEBUG_MAX_SLOTS) {
+		pr_info("pine_syscall_trace type=ptrace_spoof name=ptrace action=enospc compat=%d pid=%d tgid=%d uid=%u type=%lx count=%d comm=%s\n",
+			compat, task_pid_nr(current), task_tgid_nr(current),
+			from_kuid_munged(&init_user_ns, current_uid()),
+			type, count, current->comm);
+		pine_syscall_trace_skip(regs, -ENOSPC);
+		return true;
+	}
+
+	if (request == PINE_PTRACE_GETREGSET && base && len) {
+		n = len > PINE_HWDEBUG_MAX_BYTES ? PINE_HWDEBUG_MAX_BYTES : len;
+		clear_user((void __user *)base, n);
+	}
+
+	pr_info("pine_syscall_trace type=ptrace_spoof name=ptrace action=%s compat=%d pid=%d tgid=%d uid=%u type=%lx len=%lx comm=%s\n",
+		request == PINE_PTRACE_GETREGSET ? "getregset" : "setregset",
+		compat, task_pid_nr(current), task_tgid_nr(current),
+		from_kuid_munged(&init_user_ns, current_uid()),
+		type, len, current->comm);
+	pine_syscall_trace_skip(regs, 0);
+	return true;
+}

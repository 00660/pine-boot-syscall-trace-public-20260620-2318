+static int pine_syscall_trace_fd_proc_flags(unsigned int fd)
+{
+	struct file *file;
+	char *buf;
+	char *path;
+	int flags = 0;
+
+	file = fget(fd);
+	if (!file)
+		return 0;
+
+	buf = kmalloc(PAGE_SIZE, GFP_ATOMIC);
+	if (!buf)
+		goto out;
+
+	path = d_path(&file->f_path, buf, PAGE_SIZE);
+	if (!IS_ERR(path) && pine_str_has(path, "/proc/")) {
+		if (pine_str_has(path, "/status"))
+			flags |= PINE_PROC_FILE_STATUS;
+		if (pine_str_has(path, "/maps") || pine_str_has(path, "/smaps"))
+			flags |= PINE_PROC_FILE_MAPS;
+		if (pine_str_has(path, "/mounts") ||
+		    pine_str_has(path, "/mountinfo"))
+			flags |= PINE_PROC_FILE_MOUNTS;
+	}
+
+	kfree(buf);
+out:
+	fput(file);
+	return flags;
+}

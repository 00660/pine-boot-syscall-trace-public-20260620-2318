+static int pine_syscall_trace_path_flags(const char *path)
+{
+	int flags = 0;
+
+	if (!path || !path[0] || !strcmp(path, "-") || !strcmp(path, "<fault>"))
+		return 0;
+
+	if (pine_str_has(path, "/data/adb") ||
+	    pine_str_has(path, "/debug_ramdisk") ||
+	    pine_str_has(path, "/sbin/.magisk") ||
+	    pine_str_has(path, "/system/bin/magisk") ||
+	    pine_str_has(path, "/system/xbin/su") ||
+	    pine_str_has(path, "/system/bin/su") ||
+	    pine_str_has(path, "/vendor/bin/su") ||
+	    pine_str_has(path, "/data/local/su") ||
+	    pine_str_has(path, "/data/local/bin/su") ||
+	    pine_str_has(path, "/data/local/xbin/su") ||
+	    pine_str_has(path, "kernelsu") ||
+	    pine_str_has(path, "KernelSU"))
+		flags |= PINE_PATH_ROOT;
+
+	if (pine_str_has(path, "frida") ||
+	    pine_str_has(path, "gum-js-loop") ||
+	    pine_str_has(path, "linjector") ||
+	    pine_str_has(path, "zygisk") ||
+	    pine_str_has(path, "magisk") ||
+	    pine_str_has(path, "riru") ||
+	    pine_str_has(path, "lsposed") ||
+	    pine_str_has(path, "xposed") ||
+	    pine_str_has(path, "substrate") ||
+	    pine_str_has(path, "dobby"))
+		flags |= PINE_PATH_HOOK;
+
+	if (pine_str_has(path, "/proc/") &&
+	    (pine_str_has(path, "/proc/version") ||
+	     pine_str_has(path, "/proc/sys/kernel/pid_max")))
+		flags |= PINE_PATH_PROC;
+
+	if (pine_str_has(path, "/proc/") && pine_str_has(path, "/fd/"))
+		flags |= PINE_PATH_FD;
+
+	return flags;
+}

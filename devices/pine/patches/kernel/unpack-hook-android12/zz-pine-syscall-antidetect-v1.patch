+static void pine_syscall_trace_scrub_proc_user(unsigned long ubuf,
+					       unsigned long count,
+					       long ret,
+					       int proc_flags)
+{
+	char *buf;
+	size_t n;
+	bool changed = false;
+
+	if (ret <= 0 || !ubuf || !count)
+		return;
+
+	n = ret < count ? ret : count;
+	if (n > PINE_PROC_SCRUB_MAX)
+		n = PINE_PROC_SCRUB_MAX;
+
+	buf = kmalloc(n, GFP_ATOMIC);
+	if (!buf)
+		return;
+
+	if (!copy_from_user(buf, (void __user *)ubuf, n)) {
+		if (proc_flags & PINE_PROC_FILE_STATUS)
+			changed |= pine_syscall_trace_scrub_tracerpid(buf, n);
+		if (proc_flags & (PINE_PROC_FILE_MAPS | PINE_PROC_FILE_MOUNTS))
+			changed |= pine_syscall_trace_scrub_secret_lines(buf, n);
+		if (changed)
+			copy_to_user((void __user *)ubuf, buf, n);
+	}
+
+	kfree(buf);
+}
+
+static void pine_syscall_trace_scrub_proc_iov(unsigned long uiov,
+					      unsigned long iovcnt,
+					      long ret,
+					      bool compat,
+					      int proc_flags)
+{
+	unsigned long left;
+	unsigned long base;
+	unsigned long len;
+	unsigned long n;
+	int i;
+
+	if (ret <= 0 || !uiov || !iovcnt)
+		return;
+	if (iovcnt > 64)
+		iovcnt = 64;
+
+	left = ret;
+	for (i = 0; i < iovcnt && left > 0; i++) {
+		if (compat) {
+			struct pine_iovec32 iov32;
+
+			if (copy_from_user(&iov32,
+					   (void __user *)(uiov + i * sizeof(iov32)),
+					   sizeof(iov32)))
+				return;
+			base = iov32.iov_base;
+			len = iov32.iov_len;
+		} else {
+			struct pine_iovec64 iov64;
+
+			if (copy_from_user(&iov64,
+					   (void __user *)(uiov + i * sizeof(iov64)),
+					   sizeof(iov64)))
+				return;
+			base = iov64.iov_base;
+			len = iov64.iov_len;
+		}
+
+		if (!base || !len)
+			continue;
+		n = len < left ? len : left;
+		pine_syscall_trace_scrub_proc_user(base, n, n, proc_flags);
+		left -= n;
+	}
+}

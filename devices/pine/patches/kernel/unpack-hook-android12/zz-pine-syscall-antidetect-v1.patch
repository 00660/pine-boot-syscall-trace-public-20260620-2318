+static bool pine_syscall_trace_prctl_spoof(struct pt_regs *regs, bool compat)
+{
+	unsigned long option = regs->orig_x0;
+	long ret;
+
+	if (!(READ_ONCE(pine_syscall_trace_policy) & PINE_POLICY_NATIVE))
+		return false;
+
+	switch (option) {
+	case PINE_PR_GET_DUMPABLE:
+		ret = 1;
+		break;
+	case PINE_PR_GET_SECCOMP:
+	case PINE_PR_GET_NO_NEW_PRIVS:
+		ret = 0;
+		break;
+	case PINE_PR_SET_DUMPABLE:
+	case PINE_PR_SET_SECCOMP:
+	case PINE_PR_SET_NO_NEW_PRIVS:
+	case PINE_PR_SET_PTRACER:
+		ret = 0;
+		break;
+	default:
+		return false;
+	}
+
+	pr_info("pine_syscall_trace type=prctl_spoof name=prctl compat=%d pid=%d tgid=%d uid=%u option=%lx ret=%ld comm=%s\n",
+		compat, task_pid_nr(current), task_tgid_nr(current),
+		from_kuid_munged(&init_user_ns, current_uid()),
+		option, ret, current->comm);
+	pine_syscall_trace_skip(regs, ret);
+	return true;
+}

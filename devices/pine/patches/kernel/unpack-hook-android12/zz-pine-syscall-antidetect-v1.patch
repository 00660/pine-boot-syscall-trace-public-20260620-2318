+static bool pine_syscall_trace_should_hide_path(int flags)
+{
+	int policy = READ_ONCE(pine_syscall_trace_policy);
+
+	if (!flags)
+		return false;
+	if ((policy & PINE_POLICY_HIDE_ROOT) &&
+	    (flags & (PINE_PATH_ROOT | PINE_PATH_HOOK)))
+		return true;
+	if ((policy & PINE_POLICY_HIDE_PROC) && (flags & PINE_PATH_PROC))
+		return true;
+	return false;
+}

+static void pine_syscall_trace_exit(struct pt_regs *regs)
+{
+	bool compat = is_compat_task();
+	int nr = regs->syscallno;
+	long ret = regs_return_value(regs);
+	unsigned long fd = regs->orig_x0;
+	int proc_flags;
+	const char __user *path_arg;
+	char path[160];
+
+	if (!pine_syscall_trace_match_current())
+		return;
+	if (!(READ_ONCE(pine_syscall_trace_policy) & PINE_POLICY_HIDE_PROC))
+		return;
+
+	if (pine_syscall_trace_is_readlink_nr(nr, compat)) {
+		path_arg = pine_syscall_trace_path_arg(nr, compat,
+						       regs->orig_x0,
+						       regs->regs[1]);
+		pine_syscall_trace_copy_user(path, sizeof(path), path_arg);
+		if (pine_syscall_trace_is_proc_fd_path(path))
+			pine_syscall_trace_scrub_proc_user(
+				pine_syscall_trace_readlink_buf_arg(nr, compat, regs),
+				pine_syscall_trace_readlink_count_arg(nr, compat, regs),
+				ret, PINE_PROC_FILE_MAPS);
+		return;
+	}
+
+	proc_flags = pine_syscall_trace_fd_proc_flags((unsigned int)fd);
+	if (!proc_flags)
+		return;
+
+	if ((!compat && nr == __NR_read) ||
+	    (compat && nr == PINE_COMPAT_NR_READ)) {
+		pine_syscall_trace_scrub_proc_user(regs->regs[1],
+						   regs->regs[2], ret,
+						   proc_flags);
+		return;
+	}
+	if ((!compat && nr == __NR_pread64) ||
+	    (compat && nr == PINE_COMPAT_NR_PREAD64)) {
+		pine_syscall_trace_scrub_proc_user(regs->regs[1],
+						   regs->regs[2], ret,
+						   proc_flags);
+		return;
+	}
+	if ((!compat && nr == __NR_readv) ||
+	    (compat && nr == PINE_COMPAT_NR_READV)) {
+		pine_syscall_trace_scrub_proc_iov(regs->regs[1],
+						  regs->regs[2], ret,
+						  compat, proc_flags);
+		return;
+	}
+}
